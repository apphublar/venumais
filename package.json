{
  "name": "venumais",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "description": "VENUMAIS — gestão de vendas, estoque e crediário para pequenos negócios.",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "node --use-system-ca node_modules/next/dist/bin/next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "legacy:build": "node scripts/build.js",
    "legacy:preview": "pnpm run legacy:build && node scripts/preview.js"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@types/node": "25.2.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "typescript": "5.9.3"
  }
}
